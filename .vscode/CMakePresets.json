{
  "version": 3,
  "configurePresets": [
    {
      "name": "minGW",
      "displayName": "MinGW",
      "description": "Use MinGW0 compiler",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "C:/minGW/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "C:/minGW/bin/g++.exe"
      }
    }
  ]
}